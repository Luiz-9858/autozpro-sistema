# CONFIGURAÇÃO DO BANCO DE DADOS SUPABASE
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# URL DA API SUPABASE
SUPABASE_URL="https://[PROJECT-REF].supabase.co"

# CHAVES DO SUPABASE
SUPABASE_ANON_KEY="sua-chave-publica-aqui"

# JWT SECRET (gerar uma chave aleatória forte)
JWT_SECRET="sua-chave-secreta-super-segura-aqui"

# PORTA DO SERVIDOR
PORT=3001

# AMBIENTE
NODE_ENV="development"

# JWT CONFIGURATION
JWT_SECRET="sua-chave-secreta-de-128-caracteres-aqui-gerada-pelo-comando-crypto"
JWT_EXPIRES_IN="7d"

# SECURITY
NODE_ENV="development"
BCRYPT_ROUNDS=10